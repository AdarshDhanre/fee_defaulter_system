# =========================================================================
# Fee Defaulter System - Environment Configurations Template
# Rename this file to .env and fill in your actual credentials.
# =========================================================================

# 1. Google Gemini API Key (Get from: https://aistudio.google.com/)
# Used for Offline Challan OCR Receipt scan.
GEMINI_API_KEY=your_gemini_api_key_here

# 2. n8n Integrations (For mail and OTP automation)
API_TOKEN=your_secure_api_token_here
N8N_WEBHOOK_URL=your_n8n_webhook_url_here
N8N_RENDER_WEBHOOK_URL=your_n8n_render_webhook_url_here

# 3. Supabase PostgreSQL Connection String URI (Direct Connection)
# Copy this from Supabase Dashboard -> Project Settings -> Database -> Connection URI
DATABASE_URL=postgresql://postgres.example:[PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres
